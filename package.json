{
  "name": "hengine",
  "version": "0.1.0",
  "description": "Zero-dependency TypeScript + HTML5 Canvas 2D game engine. Browser standard APIs only.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -p tsconfig.json --watch",
    "serve:example": "cd examples/breakout && python3 -m http.server 8080",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "game-engine",
    "canvas",
    "typescript",
    "html5",
    "2d",
    "no-dependencies",
    "vanilla"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
